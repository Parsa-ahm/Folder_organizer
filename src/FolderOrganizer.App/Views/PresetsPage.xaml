<?xml version="1.0" encoding="UTF-8" ?>
<Page
    x:Class="FolderOrganizer.App.Views.PresetsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:conv="using:FolderOrganizer.App.Converters"
    xmlns:vm="using:FolderOrganizer.App.ViewModels"
    mc:Ignorable="d">

    <Page.Resources>
        <conv:HexColorToBrushConverter x:Key="HexToSolidBrush" />
        <conv:BoolToVisibilityConverter x:Key="BoolToVisible" />
    </Page.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Spacing="16" Padding="24">

            <TextBlock Text="Presets" Style="{StaticResource TitleTextBlockStyle}" />

            <!-- ============================================================ -->
            <!-- COLORS -->
            <!-- ============================================================ -->
            <Expander Header="Colors" IsExpanded="True" HorizontalAlignment="Stretch"
                      HorizontalContentAlignment="Stretch">
                <StackPanel Spacing="12">
                    <ItemsRepeater x:Name="ColorsRepeater" ItemsSource="{x:Bind ViewModel.Colors}">
                        <ItemsRepeater.Layout>
                            <UniformGridLayout MinItemWidth="48" MinItemHeight="48"
                                              MinColumnSpacing="8" MinRowSpacing="8" />
                        </ItemsRepeater.Layout>
                        <ItemsRepeater.ItemTemplate>
                            <DataTemplate x:DataType="vm:ColorPresetViewModel">
                                <Grid Width="48" Height="48"
                                      ToolTipService.ToolTip="{x:Bind Name}">
                                    <Ellipse Width="32" Height="32"
                                             HorizontalAlignment="Center"
                                             VerticalAlignment="Center"
                                             Fill="{x:Bind HexColor, Converter={StaticResource HexToSolidBrush}}" />
                                    <!-- Delete button for custom colors only -->
                                    <Button
                                        Width="18" Height="18"
                                        Padding="0"
                                        HorizontalAlignment="Right"
                                        VerticalAlignment="Top"
                                        FontFamily="Segoe Fluent Icons"
                                        Content="&#xE711;"
                                        FontSize="10"
                                        Command="{x:Bind DeleteCommand}"
                                        Visibility="{x:Bind IsCustom, Converter={StaticResource BoolToVisible}}" />
                                </Grid>
                            </DataTemplate>
                        </ItemsRepeater.ItemTemplate>
                    </ItemsRepeater>

                    <!-- Add custom color button -->
                    <Button Content="+ Add Color" Click="AddColorClicked" />
                </StackPanel>
            </Expander>

            <!-- ============================================================ -->
            <!-- ICONS -->
            <!-- ============================================================ -->
            <Expander Header="Icons" IsExpanded="False" HorizontalAlignment="Stretch"
                      HorizontalContentAlignment="Stretch">
                <StackPanel Spacing="12">
                    <GridView x:Name="IconsGrid"
                              ItemsSource="{x:Bind ViewModel.CustomIconPaths}"
                              SelectionMode="None"
                              IsItemClickEnabled="False">
                        <GridView.ItemTemplate>
                            <DataTemplate x:DataType="x:String">
                                <Grid Width="56" Height="56">
                                    <Image Width="40" Height="40"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center">
                                        <Image.Source>
                                            <BitmapImage UriSource="{x:Bind}" />
                                        </Image.Source>
                                    </Image>
                                </Grid>
                            </DataTemplate>
                        </GridView.ItemTemplate>
                    </GridView>
                    <Button Content="+ Add Icon" Click="AddIconClicked" />
                </StackPanel>
            </Expander>

            <!-- ============================================================ -->
            <!-- TAGS -->
            <!-- ============================================================ -->
            <Expander Header="Tags" IsExpanded="False" HorizontalAlignment="Stretch"
                      HorizontalContentAlignment="Stretch">
                <StackPanel Spacing="8">
                    <ListView x:Name="TagsList"
                              ItemsSource="{x:Bind ViewModel.Tags}"
                              SelectionMode="None">
                        <ListView.ItemTemplate>
                            <DataTemplate x:DataType="vm:TagEntryViewModel">
                                <Grid ColumnSpacing="8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <!-- Colored pill preview -->
                                    <Border Grid.Column="0"
                                            Width="60" Height="24"
                                            CornerRadius="12"
                                            Background="{x:Bind HexColor, Converter={StaticResource HexToSolidBrush}}" />

                                    <!-- Tag name TextBox -->
                                    <TextBox Grid.Column="1"
                                             Text="{x:Bind Name, Mode=TwoWay}"
                                             PlaceholderText="Tag name"
                                             LostFocus="TagName_LostFocus" />

                                    <!-- Color hex TextBox -->
                                    <TextBox Grid.Column="2"
                                             Text="{x:Bind HexColor, Mode=TwoWay}"
                                             PlaceholderText="#RRGGBB"
                                             Width="90"
                                             LostFocus="TagColor_LostFocus" />

                                    <!-- Delete button -->
                                    <Button Grid.Column="3"
                                            Content="&#xE711;"
                                            FontFamily="Segoe Fluent Icons"
                                            Command="{x:Bind DeleteCommand}"
                                            ToolTipService.ToolTip="Delete tag" />
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>

                    <Button Content="+ Add Tag" Click="AddTagClicked" />
                </StackPanel>
            </Expander>

        </StackPanel>
    </ScrollViewer>
</Page>
